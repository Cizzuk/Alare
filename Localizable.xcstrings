      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アラームはスヌーズ中です"
          }
        }
      }
    },
    "Alarm permission is not granted. Please enable it in Settings to use the Alare." : {
      "localizations" : {
