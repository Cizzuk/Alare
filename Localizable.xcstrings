    "Alare" : {
      "shouldTranslate" : false
    },
    "Alare's alarm will continue to snooze until you perform a Wake-up Action. To prevent oversleeping, select an action in advance that you believe will wake you up." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alareのアラームは、起床アクションを行わない限りスヌーズし続けます。目が覚めると思うアクションをあらかじめ選択して、寝坊を防止しましょう。"
          }
        }
      }
    },
    "Alarm" : {
      "localizations" : {
